{
  "name": "query-arena",
  "version": "1.0.0",
  "description": "QueryArena — plataforma de práctica de SQL estructurada",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc && npm run copy:migrations && cd client && npm install && npm run build",
    "build:backend": "tsc && npm run copy:migrations",
    "build:frontend": "cd client && npm install && npm run build",
    "copy:migrations": "node -e \"const fs=require('fs'),path=require('path');const src=path.join('src','infrastructure','migrations');const dst=path.join('dist','infrastructure','migrations');fs.mkdirSync(dst,{recursive:true});fs.readdirSync(src).filter(f=>f.endsWith('.sql')).forEach(f=>fs.copyFileSync(path.join(src,f),path.join(dst,f)));console.log('SQL migrations copied to dist/')\"",
    "start": "node dist/app.js",
    "migrate": "node dist/infrastructure/migrations/migrate.js",
    "seed:admin": "node scripts/seed-admin.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "dev": "ts-node src/app.ts"
  },
  "dependencies": {
    "bcrypt": "5.1.1",
    "dotenv": "^16.4.5",
    "express": "4.18.3",
    "jsonwebtoken": "9.0.2",
    "pg": "8.11.3",
    "winston": "3.13.0"
  },
  "devDependencies": {
    "@playwright/test": "1.44.0",
    "@types/bcrypt": "5.0.2",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.12",
    "@types/jsonwebtoken": "9.0.6",
    "@types/node": "20.12.12",
    "@types/pg": "8.11.6",
    "@types/supertest": "6.0.2",
    "@typescript-eslint/eslint-plugin": "7.10.0",
    "@typescript-eslint/parser": "7.10.0",
    "eslint": "8.57.0",
    "fast-check": "3.19.0",
    "jest": "29.7.0",
    "supertest": "7.0.0",
    "ts-jest": "29.1.4",
    "ts-node": "10.9.2",
    "typescript": "5.4.5"
  }
}
