# ─── Base de datos ────────────────────────────────────────────────────────────
# Railway inyecta DATABASE_URL automáticamente al agregar el plugin PostgreSQL.
# No es necesario configurarla manualmente en Railway.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Solo requerida para tests locales
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/queryarena_test

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Cadena aleatoria larga. Genera una con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_cadena_larga_y_aleatoria

JWT_EXPIRES_IN=24h

# ─── Seguridad ────────────────────────────────────────────────────────────────
# 10 para desarrollo, 12 para producción
BCRYPT_COST=12

# ─── Servidor ─────────────────────────────────────────────────────────────────
# Railway asigna PORT automáticamente. No es necesario configurarlo.
PORT=3000
NODE_ENV=production
