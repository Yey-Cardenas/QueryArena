# =============================================================================
# QueryArena — Production environment template
# Copy this file to .env on the server and fill in real values.
# NEVER commit the .env file with real credentials.
# =============================================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/queryarena_prod

# JWT — generate with: openssl rand -hex 64  (Linux/Mac)
#                  or: [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(64))  (PowerShell)
JWT_SECRET=REPLACE_WITH_SECURE_64_CHAR_SECRET
JWT_EXPIRES_IN=24h

# bcrypt cost factor — 12 is recommended for production
BCRYPT_COST=12

# HTTP port (default 3000)
PORT=3000

# Environment
NODE_ENV=production

# CORS — restrict to your frontend domain
CORS_ORIGIN=https://queryarena.example.com
